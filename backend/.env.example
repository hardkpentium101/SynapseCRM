# Database
DATABASE_URL=sqlite:///./crm.db

# JWT Settings
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM Settings
LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key

# Model Selection (leave empty for auto-select based on task)
MODEL_INTENT=llama-3.1-8b-instant
MODEL_EXTRACT=llama-3.1-70b-versatile
MODEL_ORCHESTRATE=llama3-groq-70b-8192-tool-use-preview

# Model Fallbacks
MODEL_INTENT_FALLBACK=llama3-groq-8b-8192-tool-use-preview
MODEL_EXTRACT_FALLBACK=mixtral-8x7b-32768

# LangSmith Tracing (optional - for visualization)
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=hcp-agent
